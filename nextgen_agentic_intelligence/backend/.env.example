# Copy this file to `.env` and fill in a real OpenAI key to get live answers.
# The placeholder below is intentionally fake; calls will 401 until replaced.
OPENAI_API_KEY=sk-REPLACE_ME

# Project standard model. Change if your account exposes a different id.
MODEL=gpt-5.5

# Optional: OpenAI-compatible gateway base URL (leave blank for default OpenAI).
OPENAI_BASE_URL=

# CORS / server
FRONTEND_ORIGIN=http://localhost:3000
HOST=0.0.0.0
PORT=8000

# --- Databricks Genie (Stage 2) ---------------------------------------------
# PAT auth. Azure host looks like https://adb-XXXXXXXXXXXX.azuredatabricks.net
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Registry of Genie spaces (JSON array, single line). Each entry becomes a tool
# `genie_<name>` routed to a subagent via `agent` (default "drg").
# Example (replace space_id values with your real space IDs):
# GENIE_SPACES=[{"name":"drg_shift","space_id":"01efYOURSPACEID","agent":"drg","description":"DRG severity tier mix and coding shift by fiscal year, US and statewise."},{"name":"drg_providers","space_id":"01efANOTHERID","agent":"drg","description":"Provider/TIN-level utilization of DRG severity codes with state and national benchmarks."}]
GENIE_SPACES=

GENIE_MAX_ROWS=50
GENIE_TIMEOUT_SECONDS=180
