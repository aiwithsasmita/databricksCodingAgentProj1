# Databricks Connection
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi_your_token_here

# Genie Space ID (get from Databricks UI after creating the space)
GENIE_SPACE_ID=01f0abcd1234567890abcdef

# LLM Endpoint (paid model recommended for complex analysis)
# Options:
#   databricks-claude-sonnet-4         (Claude via Databricks - best for reasoning)
#   databricks-meta-llama-3-3-70b-instruct  (free - good for basic queries)
LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# Production: set to 1 so the agent refuses to start with placeholder credentials
# and validates bundled CMS JSON files (770 DRGs, MCE, PCS list, etc.).
# Streamlit Cloud: set the same in Dashboard -> Secrets, or in .env for VMs.
# DRG_AGENT_STRICT=1
